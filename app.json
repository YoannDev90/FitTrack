{
  "expo": {
    "name": "Spix",
    "slug": "fittrack-app",
    "version": "11.7.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "spix",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b0c0f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.spix.app",
      "infoPlist": {
        "NSCameraUsageDescription": "$(PRODUCT_NAME) a besoin de la caméra pour détecter vos mouvements",
        "NSMotionUsageDescription": "Utilisé pour détecter automatiquement les chutes pendant vos courses / Used to automatically detect falls during your runs",
        "NSMicrophoneUsageDescription": null,
        "UIBackgroundModes": [
          "location"
        ]
      },
      "buildNumber": "11.7.0"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon/foreground.png",
        "backgroundImage": "./assets/adaptive-icon/background.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.spix.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.BODY_SENSORS",
        "android.permission.SEND_SMS",
        "android.permission.health.READ_EXERCISE",
        "android.permission.health.READ_DISTANCE",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_TOTAL_CALORIES_BURNED",
        "android.permission.health.READ_WEIGHT",
        "android.permission.health.READ_BODY_FAT",
        "android.permission.INTERNET"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "versionCode": 110700,
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Permettez à $(PRODUCT_NAME) d'accéder à votre position pendant vos courses.",
          "locationAlwaysAndWhenInUsePermission": "Permettez à $(PRODUCT_NAME) d'accéder à votre position en arrière-plan pour poursuivre le tracking de course.",
          "isAndroidBackgroundLocationEnabled": true,
          "isIosBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#D79686"
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "$(PRODUCT_NAME) a besoin de la caméra pour détecter vos mouvements",
          "enableFrameProcessors": true
        }
      ],
      "./plugins/withMediaPipeModel.js",
      "./plugins/withSpixSmsManager.js",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0",
            "minSdkVersion": 26
          }
        }
      ],
      "expo-audio",
      "expo-localization",
      "expo-secure-store",
      "expo-sharing",
      [
        "expo-font",
        {
          "fonts": [
            "node_modules/@expo-google-fonts/syne/400Regular/Syne_400Regular.ttf",
            "node_modules/@expo-google-fonts/syne/700Bold/Syne_700Bold.ttf",
            "node_modules/@expo-google-fonts/syne/800ExtraBold/Syne_800ExtraBold.ttf"
          ]
        }
      ],
      "@maplibre/maplibre-react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fa564092-790e-4f01-9663-7b0420577cc8"
      },
      "buildFlavor": "standard"
    },
    "owner": "luckycookie"
  }
}
